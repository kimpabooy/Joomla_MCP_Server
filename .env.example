# Joomla Server Configuration
# LOCAL DEVELOPMENT: Use http://localhost:8080 or http://host.docker.internal:8080
# PRODUCTION: Use your actual domain or server IP (e.g., http://joomla.example.com)
JOOMLA_SITE_URL="http://localhost:8080"
JOOMLA_API_URL="http://localhost:8080/api/index.php/v1"

# Optional: override URL used for status checks (useful in Docker/production)
# JOOMLA_SITE_CHECK_URL="http://host.docker.internal:8080/api/index.php/v1"

# Get your API token from Joomla: System > Users > Create API Token
JOOMLA_API_TOKEN="your-joomla-api-token-here"

# OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-your-openai-key-here"
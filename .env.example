# Viktigt:
# - Produktion: använd din riktiga domän/IP i .env.
# - JOOMLA_SITE_URL = Joomla-bas-URL.
# - JOOMLA_API_URL = API-URL med /api/index.php/v1.
# - Docker lokalt: localhost i containern pekar på containern själv.
#   Använd host.docker.internal, eller host.docker.internal.localhost som fallback.

JOOMLA_SITE_URL="http://localhost:8080"
JOOMLA_API_URL="http://localhost:8080/api/index.php/v1"

# Get your API token from Joomla: System > Users > Create API Token
JOOMLA_API_TOKEN="your-joomla-api-token-here"

# OpenAI API key from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-your-openai-key-here"